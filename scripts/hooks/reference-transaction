"""
Reference-transaction hook: auto-bump to dev version after pushing a release.

This hook is triggered when git updates references. After a successful push
of a release version (X.Y.Z without .dev suffix) to mainline, it automatically:
1. Bumps the version to X.Y.(Z+1).dev
2. Commits the change
3. Pushes the dev commit

This ensures the release commit is pushed alone, triggering the GitHub release
workflow correctly, while automating the follow-up dev version bump.
"""

import re
import subprocess
import sys
from pathlib import Path


def get_version_from_pyproject() -> tuple[int, int, int, bool] | None:
    pyproject = Path("pyproject.toml")
    if not pyproject.exists():
        return None

    content = pyproject.read_text()
    match = re.search(r'version\s*=\s*"(\d+)\.(\d+)\.(\d+)(\.dev)?"', content)
    if not match:
        return None

    return (
        int(match.group(1)),
        int(match.group(2)),
        int(match.group(3)),
        match.group(4) is not None,
    )


def is_mainline_push_to_remote(stdin_lines: list[str]) -> bool:
    for line in stdin_lines:
        parts = line.strip().split()
        if len(parts) >= 3:
            ref_name = parts[2]
            if ref_name == "refs/remotes/origin/mainline":
                return True
    return False


def main() -> int:
    if len(sys.argv) < 2:
        return 0

    state = sys.argv[1]

    if state != "committed":
        return 0

    stdin_lines = sys.stdin.readlines()

    if not is_mainline_push_to_remote(stdin_lines):
        return 0

    version_info = get_version_from_pyproject()
    if version_info is None:
        return 0

    major, minor, patch, is_dev = version_info

    if is_dev:
        return 0

    next_version = f"{major}.{minor}.{patch + 1}.dev"

    pyproject = Path("pyproject.toml")
    content = pyproject.read_text()
    new_content = re.sub(
        r'version\s*=\s*"[^"]+"',
        f'version = "{next_version}"',
        content,
        count=1,
    )
    pyproject.write_text(new_content)

    subprocess.run(["git", "add", "pyproject.toml"], check=True)
    subprocess.run(
        ["git", "commit", "-m", f"🔖 Start of pre-release v{next_version}"],
        check=True,
        env={**dict(subprocess.os.environ), "GIT_EDITOR": ":"},
    )

    subprocess.run(["git", "push"], check=True)

    print(f"\nAuto-bumped version to {next_version} and pushed")
    return 0


if __name__ == "__main__":
    sys.exit(main())